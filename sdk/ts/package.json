{
  "name": "relayly-client",
  "version": "0.1.0",
  "description": "Client library for the Relayly WebSocket relay server — simple, secure device-to-device messaging for local-first apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "relay",
    "websocket",
    "local-first",
    "e2e-encryption",
    "p2p",
    "pairing",
    "nacl",
    "tweetnacl"
  ],
  "author": "NIKX-Tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NIKX-Tech/relayly",
    "directory": "sdk/ts"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
